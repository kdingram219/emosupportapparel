        `,
        signs: `
            <svg class="w-72 h-72 transition-colors duration-500" id="mockup-svg-canvas" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.2">
                <rect id="svg-part-body" x="30" y="50" width="180" height="140" rx="8" fill="currentColor" fill-opacity="0.03" stroke-linejoin="round"/>
                <circle cx="40" cy="60" r="3" fill="currentColor"/>
                <circle cx="200" cy="60" r="3" fill="currentColor"/>
                <circle cx="200" cy="180" r="3" fill="currentColor"/>
                <circle cx="40" cy="180" r="3" fill="currentColor"/>
            </svg>
        `,
        coasters: `
            <svg class="w-72 h-72 transition-colors duration-500" id="mockup-svg-canvas" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.2">
                <circle id="svg-part-body" cx="120" cy="120" r="80" fill="currentColor" fill-opacity="0.03" stroke-linejoin="round"/>
                <circle cx="120" cy="120" r="72" stroke-dasharray="4,4" stroke-opacity="0.5"/>
            </svg>
        `,
        pens: `
            <svg class="w-72 h-72 transition-colors duration-500" id="mockup-svg-canvas" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.2">
                <path id="svg-part-body" d="M40,200 L50,190 L180,60 L170,50 L40,180 Z" fill="currentColor" fill-opacity="0.05" stroke-linejoin="round"/>
                <path d="M40,200 L35,205 L40,180" stroke-linejoin="round"/>
                <path d="M160,80 L150,70" stroke-width="2"/>
            </svg>
        `
    };

    // Prepopulate designer with routing search query parameter if preloaded
    window.addEventListener('DOMContentLoaded', () => {
        const params = new URLSearchParams(window.location.search);
        const preloadedProduct = params.get('product');
        if (preloadedProduct && svgTemplates[preloadedProduct]) {
            document.getElementById('canvas-select').value = preloadedProduct;
            changeBaseProduct(preloadedProduct);
        }
    });

    // Handle dynamically changing the base product SVG mockup
    function changeBaseProduct(category) {
        const holder = document.getElementById('mockup-svg-holder');
        const selectEl = document.getElementById('canvas-select');
        const option = selectEl.options[selectEl.selectedIndex];
        
        // Update price
        currentBasePrice = parseFloat(option.getAttribute('data-price'));
        updatePriceSummary();

        // Map sub-categories to standard SVG representations
        const categoryMap = {
            "pet-tags": "coasters",
            "animal-tags": "coasters",
            "bandanas": "towels",
            "collars": "towels",
            "leashes": "towels",
            "training-clickers": "pens",
            "wine-glasses": "mugs",
            "mason-jars": "mugs",
            "stainless-steel-water-bottles": "tumblers",
            "boxer-briefs-briefs": "tees",
            "slippers": "pillows",
            "canvas-tennis-shoes": "pillows",
            "shin-guards": "signs",
            "plaques": "signs",
            "picture-frames": "signs",
            "decorative-fans": "coasters",
            "throw-blankets": "towels",
            "pot-holders": "coasters",
            "paperclips": "pens",
            "magnets": "coasters",
            "stickers": "coasters"
        };
        const templateKey = categoryMap[category] || category;

        // Update SVG HTML
        const template = svgTemplates[templateKey] || svgTemplates.hoodies;
        
        // Retain text layer and upload image layer DOM elements
        const userImgLayer = document.getElementById('uploaded-image-layer');
        const userTxtLayer = document.getElementById('custom-text-layer');
        
        holder.innerHTML = template;
        holder.appendChild(userImgLayer);
        holder.appendChild(userTxtLayer);

        // Apply selected base colorway directly to background of SVG elements
        applyMockupColor();
    }

    // Canvas Background/Colorway selectors
    function changeCanvasColor(colorCode, btn) {
        // Remove active ring styling from all colorway buttons
        document.querySelectorAll('#colorway-container button').forEach(b => {
            b.classList.remove('border-gold', 'border-2');
            b.classList.add('border-charcoal/20', 'border');
        });
        
        // Highlight active button
        btn.classList.add('border-gold', 'border-2');
        btn.classList.remove('border-charcoal/20', 'border');

        selectedColor = colorCode;
        applyMockupColor();
    }

    function applyMockupColor() {
        const svgCanvas = document.getElementById('mockup-svg-canvas');
        if (!svgCanvas) return;

        // Apply fill/stroke to internal dynamic segments representing the canvas
        const bodyPart = svgCanvas.querySelector('#svg-part-body') || svgCanvas.querySelector('rect') || svgCanvas.querySelector('circle');
        if (bodyPart) {
            bodyPart.style.fill = selectedColor;
            bodyPart.style.fillOpacity = "1.0";
        }

        // Apply a slightly darker accent fill to sleeves or accents
        const sleevesL = svgCanvas.querySelector('#svg-part-sleeves-l');
        const sleevesR = svgCanvas.querySelector('#svg-part-sleeves-r');
        const pocket = svgCanvas.querySelector('#svg-part-pocket');
        const brim = svgCanvas.querySelector('#svg-part-brim');
        const handle = svgCanvas.querySelector('#svg-part-handle');

        const lighterHex = darkenHex(selectedColor, 10);
        if (sleevesL) sleevesL.style.fill = lighterHex;
        if (sleevesR) sleevesR.style.fill = lighterHex;
        if (pocket) pocket.style.fill = lighterHex;
        if (brim) brim.style.fill = lighterHex;
        if (handle) handle.style.fill = lighterHex;

        // Automatically toggle SVG outline strokes from black to white based on background brightness
        const isDark = isColorDark(selectedColor);
        svgCanvas.style.color = isDark ? '#F8F4EE' : '#2B2B2B';
    }

    // Helper: Darken colors mathematically for accent textures
    function darkenHex(hex, percent) {
        if (hex === '#F8F4EE') return '#EFEAE0';
        if (hex === '#2B2B2B') return '#1A1A1A';
        if (hex === '#A8B5A2') return '#98A592';
        if (hex === '#8FA9C7') return '#7F99B7';
        return hex;
    }

    // Helper: detect brightness
    function isColorDark(hex) {
        return hex === '#2B2B2B';
    }

    // Handle Custom Text input
    function updateCustomText(text) {
        const layer = document.getElementById('custom-text-layer');
        const element = document.getElementById('sublimation-user-text');
        
        selectedText = text;
        if (text.trim() === '') {
            layer.style.display = 'none';
            hasCustomText = false;
        } else {
            layer.style.display = 'flex';
            element.textContent = text;
            hasCustomText = true;
        }
        updatePriceSummary();
    }

    // Adjust Font and Scale on text
    function changeFont(fontClass) {
        const element = document.getElementById('sublimation-user-text');
        element.className = "text-center break-words max-w-[180px] leading-snug " + fontClass;
    }

    function changeTextSize(size) {
        const element = document.getElementById('sublimation-user-text');
        element.style.fontSize = size + "px";
    }

    function changeTextColor(color) {
        const element = document.getElementById('sublimation-user-text');
        element.style.color = color;
    }

    // Handle Image Upload previews
    function handleImageUpload(input) {
        const file = input.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = function(e) {
            const layer = document.getElementById('uploaded-image-layer');
            const img = document.getElementById('sublimation-user-image');
            
            img.src = e.target.result;
            layer.style.display = 'flex';
            document.getElementById('image-scale-container').style.display = 'block';
            hasCustomImage = true;
            updatePriceSummary();
        }
        reader.readAsDataURL(file);
    }

    function changeImageScale(scale) {
        const img = document.getElementById('sublimation-user-image');
        img.style.transform = `scale(${scale})`;
    }

    // Update dynamic pricing
    function updatePriceSummary() {
        let price = currentBasePrice;
        if (hasCustomText) price += 5.00; // Premium charge
        if (hasCustomImage) price += 8.00; // Premium print charge

        document.getElementById('dynamic-price').textContent = `${price.toFixed(2)}`;
    }

    function selectCustomSize(btn) {
        // Remove active styling from siblings
        btn.parentNode.querySelectorAll('button').forEach(b => {
            b.classList.remove('bg-charcoal', 'text-cream', 'border-charcoal');
            b.classList.add('border-charcoal/10', 'text-charcoal');
        });
        // Add active style to selected
        btn.classList.add('bg-charcoal', 'text-cream', 'border-charcoal');
        btn.classList.remove('border-charcoal/10', 'text-charcoal');
        
        selectedSize = btn.innerText.trim();
    }

    async function submitCustomOrder() {
        const btn = document.getElementById('custom-checkout-btn');
        const btnText = document.getElementById('custom-btn-text');
        const spinner = document.getElementById('custom-btn-spinner');
        
        if (!btn || btn.disabled) return;
        
        // Show loading state
        btn.disabled = true;
        btnText.innerText = "Initiating checkout...";
        spinner.classList.remove('hidden');
        
        const selectEl = document.getElementById('canvas-select');
        const itemName = selectEl.options[selectEl.selectedIndex].text.split(' (
)[0];
        const categoryId = selectEl.value;
        
        let colorName = "Cream";
        if (selectedColor === '#2B2B2B') colorName = "Charcoal";
        if (selectedColor === '#A8B5A2') colorName = "Sage Green";
        if (selectedColor === '#8FA9C7') colorName = "Dusty Blue";

        // Calculate final price dynamically
        let finalPrice = currentBasePrice;
        if (hasCustomText) finalPrice += 5.00;
        if (hasCustomImage) finalPrice += 8.00;

        const imgEl = document.getElementById('sublimation-user-image');
        const customImageSrc = hasCustomImage ? imgEl.src : '';

        try {
            const response = await fetch('/create-checkout-session', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    productId: 'custom-sublimation-' + categoryId,
                    name: `Customized ESA ${itemName}`,
                    price: finalPrice,
                    size: selectedSize,
                    color: colorName,
                    customText: selectedText,
                    customImage: customImageSrc,
                    category: categoryId
                })
            });

            const data = await response.json();

            if (response.ok && data.url) {
                // Redirect user to Stripe Checkout (or our mock checkout in dev)
                window.location.href = data.url;
            } else {
                throw new Error(data.error || "Unable to initiate payment session.");
            }
        } catch (error) {
            console.error("Custom order payment error:", error);
            alert("A minor inconvenience occurred while connecting to Stripe: " + error.message);
            
            // Restore button state
            btn.disabled = false;
            btnText.innerText = "Order Custom Creation";
            spinner.classList.add('hidden');
        }
    }

    // --- PAYPAL CHECKOUT INTEGRATION ---
    let paypalButtonsRendered = false;

    function switchPaymentMethod(method) {
        const stripeBtn = document.getElementById('custom-checkout-btn');
        const paypalBtnContainer = document.getElementById('paypal-button-container');
        const stripeTab = document.getElementById('pay-stripe-tab');
        const paypalTab = document.getElementById('pay-paypal-tab');

        if (method === 'stripe') {
            stripeBtn.classList.remove('hidden');
            paypalBtnContainer.classList.add('hidden');
            
            stripeTab.className = "py-3 px-4 border-2 border-charcoal text-charcoal font-semibold rounded-xl text-xs uppercase tracking-wider flex items-center justify-center space-x-2 transition-all";
            paypalTab.className = "py-3 px-4 border border-charcoal/10 text-charcoal/60 hover:border-charcoal/30 font-semibold rounded-xl text-xs uppercase tracking-wider flex items-center justify-center space-x-2 transition-all";
        } else if (method === 'paypal') {
            stripeBtn.classList.add('hidden');
            paypalBtnContainer.classList.remove('hidden');
            
            paypalTab.className = "py-3 px-4 border-2 border-charcoal text-charcoal font-semibold rounded-xl text-xs uppercase tracking-wider flex items-center justify-center space-x-2 transition-all";
            stripeTab.className = "py-3 px-4 border border-charcoal/10 text-charcoal/60 hover:border-charcoal/30 font-semibold rounded-xl text-xs uppercase tracking-wider flex items-center justify-center space-x-2 transition-all";

            if (!paypalButtonsRendered) {
                renderPayPalButtons();
            }
        }
    }

    function renderPayPalButtons() {
        if (typeof paypal === 'undefined') {
            console.error("PayPal SDK not loaded.");
            return;
        }

        paypal.Buttons({
            style: {
                layout: 'vertical',
                color:  'gold',
                shape:  'rect',
                label:  'paypal',
                height: 48
            },
            createOrder: function(data, actions) {
                const selectEl = document.getElementById('canvas-select');
                const itemName = selectEl.options[selectEl.selectedIndex].text.split(' (')[0];
                const categoryId = selectEl.value;
                
                let colorName = "Cream";
                if (selectedColor === '#2B2B2B') colorName = "Charcoal";
                if (selectedColor === '#A8B5A2') colorName = "Sage Green";
                if (selectedColor === '#8FA9C7') colorName = "Dusty Blue";

                let finalPrice = currentBasePrice;
                if (hasCustomText) finalPrice += 5.00;
                if (hasCustomImage) finalPrice += 8.00;

                const imgEl = document.getElementById('sublimation-user-image');
                const customImageSrc = hasCustomImage ? imgEl.src : '';

                return fetch('/create-paypal-order', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        productId: 'custom-sublimation-' + categoryId,
                        name: `Customized ESA ${itemName}`,
                        price: finalPrice,
                        size: selectedSize,
                        color: colorName,
                        customText: selectedText,
                        customImage: customImageSrc,
                        category: categoryId
                    })
                })
                .then(res => {
                    if (!res.ok) {
                        throw new Error("Failed to create order on server.");
                    }
                    return res.json();
                })
                .then(order => order.id)
                .catch(err => {
                    console.error("PayPal Create Order Error:", err);
                    alert("A minor inconvenience occurred: " + err.message);
                });
            },
            onApprove: function(data, actions) {
                const selectEl = document.getElementById('canvas-select');
                const itemName = selectEl.options[selectEl.selectedIndex].text.split(' (')[0];
                const categoryId = selectEl.value;
                
                let colorName = "Cream";
                if (selectedColor === '#2B2B2B') colorName = "Charcoal";
                if (selectedColor === '#A8B5A2') colorName = "Sage Green";
                if (selectedColor === '#8FA9C7') colorName = "Dusty Blue";

                let finalPrice = currentBasePrice;
                if (hasCustomText) finalPrice += 5.00;
                if (hasCustomImage) finalPrice += 8.00;

                return fetch('/capture-paypal-order', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        orderId: data.orderID,
                        productId: 'custom-sublimation-' + categoryId,
                        name: `Customized ESA ${itemName}`,
                        price: finalPrice,
                        size: selectedSize,
                        color: colorName,
                        customText: selectedText,
                        category: categoryId
                    })
                })
                .then(res => res.json())
                .then(details => {
                    const queryParams = new URLSearchParams({
                        session_id: data.orderID,
                        productId: 'custom-sublimation-' + categoryId,
                        name: `Customized ESA ${itemName}`,
                        price: finalPrice,
                        size: selectedSize,
                        color: colorName,
                        customText: selectedText,
                        paypal: 'true'
                    }).toString();
                    window.location.href = `/success?${queryParams}`;
                })
                .catch(err => {
                    console.error("PayPal Capture Order Error:", err);
                    alert("Unable to capture payment. Please contact support.");
                });
            },
            onError: function(err) {
                console.error("PayPal Error Callback:", err);
                alert("An error occurred with PayPal checkout. Please try again.");
            }
        }).render('#paypal-button-container');

        paypalButtonsRendered = true;
    }
</script>

<!-- PayPal JS SDK Script -->
<script src="https://www.paypal.com/sdk/js?client-id=<%= paypalClientId %>&currency=USD"></script>

    function closeModal() {
        const modal = document.getElementById('success-modal');
        modal.classList.add('opacity-0', 'invisible');
        modal.classList.remove('opacity-100', 'visible');
    }
</script>
