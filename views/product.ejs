<!-- Product Detail Page of Emotional Support Apparel by K&D -->

<!-- Breadcrumb -->
<div class="bg-cream border-b border-charcoal/5 py-4">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex items-center space-x-2 text-xs uppercase tracking-widest text-charcoal/40">
            <a href="/" class="hover:text-gold transition-colors">Home</a>
            <span>/</span>
            <a href="/collections/<%= product.collections[0] %>" class="hover:text-gold transition-colors">Collection</a>
            <span>/</span>
            <span class="text-charcoal"><%= product.name %></span>
        </div>
    </div>
</div>

<!-- Product Showcase & Details Section -->
<section class="py-12 sm:py-20 bg-[#F8F4EE]">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        
        <!-- Left: Beautiful Product Visual/Mockup -->
        <div class="lg:col-span-6 flex flex-col space-y-6">
            <div class="relative aspect-square bg-cream border border-charcoal/10 rounded-2xl flex items-center justify-center p-12 shadow-md overflow-hidden">
                
                <% if (product.badge) { %>
                    <span class="absolute top-4 left-4 bg-charcoal text-cream text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded shadow-md">
                        <%= product.badge %>
                    </span>
                <% } %>

                <span class="absolute top-4 right-4 text-xs font-semibold text-gold bg-gold/10 px-3 py-1 rounded-full uppercase tracking-wider">
                    Luxury Grade
                </span>

                <!-- Stylized CSS/SVG Product Representation -->
                <div class="w-full h-full max-w-sm flex items-center justify-center text-charcoal">
                    <img src="/images/products/<%= product.id %>.png" 
                         data-attempt="jpg"
                         onerror="handleProductImageError(this, '<%= product.id %>', '<%= product.category %>')" 
                         alt="<%= product.name %>" 
                         class="w-72 h-72 object-contain transition-transform duration-500 hover:scale-105" />
                </div>

                <!-- Sublimation Placement lines indicator -->
                <div class="absolute inset-0 border border-gold/15 m-8 pointer-events-none rounded flex items-center justify-center">
                    <span class="text-[9px] uppercase tracking-widest text-gold/30 font-bold bg-cream px-2">Sublimation Zone</span>
                </div>
            </div>

            <!-- Double-path info note -->
            <p class="text-xs text-charcoal/40 text-center italic">
                * Note: Outline represents high-end structure. Finished printed item matches luxury specifications.
            </p>
        </div>
        
        <!-- Right: Sophisticated Details -->
        <div class="lg:col-span-6 space-y-8">
            
            <div class="space-y-4">
                <span class="text-xs font-bold uppercase tracking-widest text-gold">Branded Collection Drop</span>
                <h1 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-extrabold text-charcoal tracking-tight"><%= product.name %></h1>
                
                <!-- Review star layout -->
                <div class="flex items-center space-x-3">
                    <div class="flex text-gold space-x-0.5">
                        <% for (let i = 0; i < 5; i++) { %>
                            <svg class="w-4 h-4 fill-current" viewBox="0 0 240 240">
                                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                            </svg>
                        <% } %>
                    </div>
                    <span class="text-xs text-charcoal/50 uppercase tracking-widest">(★★★★★ 48 Reviews)</span>
                </div>

                <div class="flex items-center space-x-4">
                    <p class="text-2xl font-bold text-charcoal">$<%= product.price.toFixed(2) %></p>
                    <% if (product.price >= 65) { %>
                        <span class="text-xs bg-gold/10 text-gold font-bold uppercase tracking-widest px-2.5 py-1 rounded-full">
                            ✓ Free Shipping
                        </span>
                    <% } else { %>
                        <span class="text-xs bg-charcoal/5 text-charcoal/50 uppercase tracking-widest px-2.5 py-1 rounded-full">
                            +$65 for Free Shipping
                        </span>
                    <% } %>
                </div>
            </div>

            <!-- Witty Tag block -->
            <div class="bg-gold/10 border-l-2 border-gold p-5 rounded-r-lg">
                <span class="text-[10px] font-bold uppercase tracking-widest text-gold block mb-1">Comfort Slogan / Witty Tag</span>
                <p class="font-serif italic text-lg text-charcoal/80 leading-relaxed">
                    "<%= product.wittyTag %>"
                </p>
            </div>

            <!-- Description -->
            <div class="space-y-3">
                <h3 class="text-xs font-bold uppercase tracking-widest text-charcoal/50">Detailed Breakdown</h3>
                <p class="text-charcoal/70 text-sm leading-relaxed"><%= product.description %></p>
            </div>

            <!-- Specs list -->
            <% if (product.features && product.features.length > 0) { %>
                <div class="space-y-3">
                    <h3 class="text-xs font-bold uppercase tracking-widest text-charcoal/50">Specifications</h3>
                    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs text-charcoal/70">
                        <% product.features.forEach(feat => { %>
                            <li class="flex items-center space-x-2">
                                <span class="text-gold">•</span>
                                <span><%= feat %></span>
                            </li>
                        <% }); %>
                    </ul>
                </div>
            <% } %>

            <!-- Interactive color selector -->
            <div class="space-y-3">
                <h3 class="text-xs font-bold uppercase tracking-widest text-charcoal/50">Select Colorway</h3>
                <div class="flex items-center space-x-3">
                    <button onclick="selectColor(this, 'Charcoal')" class="w-8 h-8 rounded-full border-2 border-charcoal bg-charcoal shadow-sm ring-2 ring-gold ring-offset-2" aria-label="Charcoal color"></button>
                    <button onclick="selectColor(this, 'Cream')" class="w-8 h-8 rounded-full border border-charcoal/20 bg-cream hover:border-charcoal shadow-sm" aria-label="Cream color"></button>
                    <button onclick="selectColor(this, 'Sage Green')" class="w-8 h-8 rounded-full border border-charcoal/20 bg-[#A8B5A2] hover:border-charcoal shadow-sm" aria-label="Sage Green color"></button>
                    <button onclick="selectColor(this, 'Dusty Blue')" class="w-8 h-8 rounded-full border border-charcoal/20 bg-[#8FA9C7] hover:border-charcoal shadow-sm" aria-label="Dusty Blue color"></button>
                </div>
            </div>

            <!-- Interactive size selector -->
            <div class="space-y-3">
                <div class="flex items-center justify-between">
                    <h3 class="text-xs font-bold uppercase tracking-widest text-charcoal/50">Select Size</h3>
                    <button onclick="alert('Sizing Guide:\n- Heavyweight pieces are relaxed oversized fits.\n- Standard accessories are one-size fits all.')" class="text-xs text-gold underline hover:text-gold/80">Sizing Guide</button>
                </div>
                <div class="flex flex-wrap gap-2">
                    <% const sizes = ["XS", "S", "M", "L", "XL", "XXL"]; %>
                    <% sizes.forEach(size => { %>
                        <button onclick="selectSize(this)" class="px-4 py-2 border <%= size === 'M' ? 'bg-charcoal text-cream border-charcoal' : 'border-charcoal/10 text-charcoal' %> hover:border-charcoal rounded text-xs font-semibold tracking-wider transition-all duration-200">
                            <%= size %>
                        </button>
                    <% }); %>
                </div>
            </div>

            <!-- Payment Method Selector -->
            <div class="space-y-3 pt-2">
                <h3 class="text-xs font-bold uppercase tracking-widest text-charcoal/50">Select Payment Method</h3>
                <div class="grid grid-cols-2 gap-4">
                    <button id="pay-stripe-tab" onclick="switchPaymentMethod('stripe')" class="py-3 px-4 border-2 border-charcoal text-charcoal font-semibold rounded-xl text-xs uppercase tracking-wider flex items-center justify-center space-x-2 transition-all">
                        <span>💳 Credit Card</span>
                    </button>
                    <button id="pay-paypal-tab" onclick="switchPaymentMethod('paypal')" class="py-3 px-4 border border-charcoal/10 text-charcoal/60 hover:border-charcoal/30 font-semibold rounded-xl text-xs uppercase tracking-wider flex items-center justify-center space-x-2 transition-all">
                        <span>🅿️ PayPal</span>
                    </button>
                </div>
            </div>

            <!-- Action buttons: Dual-path checkout & customize -->
            <div class="space-y-4 pt-4 border-t border-charcoal/5">
                <div class="flex flex-col sm:flex-row gap-4">
                    <!-- Standard Cart / Buy Now with Stripe -->
                    <button id="checkout-btn" onclick="initiateStripeCheckout()" class="flex-grow flex items-center justify-center px-8 py-4 bg-charcoal hover:bg-charcoal/90 text-cream font-bold tracking-wider uppercase text-xs rounded-full shadow-lg transition-all">
                        <span id="btn-text">Secure Comfort Now (Stripe)</span>
                        <svg id="btn-spinner" class="hidden animate-spin ml-2 h-4 w-4 text-cream" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    </button>
                    
                    <!-- PayPal Smart Payment Buttons Container -->
                    <div id="paypal-button-container" class="hidden flex-grow relative z-10 min-w-[200px]"></div>
                    
                    <!-- Sublimation customization path -->
                    <% if (product.customizable) { %>
                        <a href="/design?product=<%= product.category %>" class="flex-grow flex items-center justify-center px-8 py-4 border border-gold hover:bg-gold hover:text-charcoal text-charcoal font-bold tracking-wider uppercase text-xs rounded-full transition-all">
                            Customize (Live Preview)
                        </a>
                    <% } %>
                </div>

                <p class="text-[10px] text-charcoal/40 text-center uppercase tracking-wider">
                    ⚡ Free shipping on orders $65+ · Free processing on luxury pre-orders · Shipping in 2026
                </p>
            </div>

        </div>
    </div>
</section>

<script>
    let selectedSize = 'M';
    let selectedColor = 'Charcoal';

    function selectSize(btn) {
        // Remove active styling from siblings
        btn.parentNode.querySelectorAll('button').forEach(b => {
            b.classList.remove('bg-charcoal', 'text-cream', 'border-charcoal');
            b.classList.add('border-charcoal/10', 'text-charcoal');
        });
        // Add active style to selected
        btn.classList.add('bg-charcoal', 'text-cream', 'border-charcoal');
        btn.classList.remove('border-charcoal/10', 'text-charcoal');
        
        selectedSize = btn.innerText.trim();
    }

    function selectColor(btn, colorName) {
        // Remove offset/ring class from all color button siblings
        btn.parentNode.querySelectorAll('button').forEach(b => {
            b.classList.remove('ring-2', 'ring-gold', 'ring-offset-2');
        });
        // Add ring highlight to selected color
        btn.classList.add('ring-2', 'ring-gold', 'ring-offset-2');
        
        selectedColor = colorName;
    }

    async function initiateStripeCheckout() {
        const btn = document.getElementById('checkout-btn');
        const btnText = document.getElementById('btn-text');
        const spinner = document.getElementById('btn-spinner');
        
        if (!btn || btn.disabled) return;
        
        // Show loading state
        btn.disabled = true;
        btnText.innerText = "Processing checkout...";
        spinner.classList.remove('hidden');
        
        try {
            const response = await fetch('/create-checkout-session', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    productId: '<%= product.id %>',
                    name: '<%= product.name %>',
                    price: <%= product.price %>,
                    size: selectedSize,
                    color: selectedColor
                })
            });
            
            const data = await response.json();
            
            if (response.ok && data.url) {
                // Redirect user to Stripe Checkout (or our mock checkout in dev)
                window.location.href = data.url;
            } else {
                throw new Error(data.error || "Unable to initiate payment session.");
            }
        } catch (error) {
            console.error("Payment error:", error);
            alert("A minor inconvenience occurred while connecting to Stripe: " + error.message);
            
            // Restore button state
            btn.disabled = false;
            btnText.innerText = "Secure Comfort Now (Stripe)";
            spinner.classList.add('hidden');
        }
    }

    // --- PAYPAL CHECKOUT INTEGRATION ---
    let paypalButtonsRendered = false;

    function switchPaymentMethod(method) {
        const stripeBtn = document.getElementById('checkout-btn');
        const paypalBtnContainer = document.getElementById('paypal-button-container');
        const stripeTab = document.getElementById('pay-stripe-tab');
        const paypalTab = document.getElementById('pay-paypal-tab');

        if (method === 'stripe') {
            stripeBtn.classList.remove('hidden');
            paypalBtnContainer.classList.add('hidden');
            
            stripeTab.className = "py-3 px-4 border-2 border-charcoal text-charcoal font-semibold rounded-xl text-xs uppercase tracking-wider flex items-center justify-center space-x-2 transition-all";
            paypalTab.className = "py-3 px-4 border border-charcoal/10 text-charcoal/60 hover:border-charcoal/30 font-semibold rounded-xl text-xs uppercase tracking-wider flex items-center justify-center space-x-2 transition-all";
        } else if (method === 'paypal') {
            stripeBtn.classList.add('hidden');
            paypalBtnContainer.classList.remove('hidden');
            
            paypalTab.className = "py-3 px-4 border-2 border-charcoal text-charcoal font-semibold rounded-xl text-xs uppercase tracking-wider flex items-center justify-center space-x-2 transition-all";
            stripeTab.className = "py-3 px-4 border border-charcoal/10 text-charcoal/60 hover:border-charcoal/30 font-semibold rounded-xl text-xs uppercase tracking-wider flex items-center justify-center space-x-2 transition-all";

            if (!paypalButtonsRendered) {
                renderPayPalButtons();
            }
        }
    }

    function renderPayPalButtons() {
        if (typeof paypal === 'undefined') {
            console.error("PayPal SDK not loaded.");
            return;
        }

        paypal.Buttons({
            style: {
                layout: 'vertical',
                color:  'gold',
                shape:  'rect',
                label:  'paypal',
                height: 48
            },
            createOrder: function(data, actions) {
                return fetch('/create-paypal-order', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        productId: '<%= product.id %>',
                        name: '<%= product.name %>',
                        price: <%= product.price %>,
                        size: selectedSize,
                        color: selectedColor
                    })
                })
                .then(res => {
                    if (!res.ok) {
                        throw new Error("Failed to create order on server.");
                    }
                    return res.json();
                })
                .then(order => order.id)
                .catch(err => {
                    console.error("PayPal Create Order Error:", err);
                    alert("A minor inconvenience occurred: " + err.message);
                });
            },
            onApprove: function(data, actions) {
                return fetch('/capture-paypal-order', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        orderId: data.orderID,
                        productId: '<%= product.id %>',
                        name: '<%= product.name %>',
                        price: <%= product.price %>,
                        size: selectedSize,
                        color: selectedColor
                    })
                })
                .then(res => res.json())
                .then(details => {
                    const queryParams = new URLSearchParams({
                        session_id: data.orderID,
                        productId: '<%= product.id %>',
                        name: '<%= product.name %>',
                        price: <%= product.price %>,
                        size: selectedSize,
                        color: selectedColor,
                        paypal: 'true'
                    }).toString();
                    window.location.href = `/success?${queryParams}`;
                })
                .catch(err => {
                    console.error("PayPal Capture Order Error:", err);
                    alert("Unable to capture payment. Please contact support.");
                });
            },
            onError: function(err) {
                console.error("PayPal Error Callback:", err);
                alert("An error occurred with PayPal checkout. Please try again.");
            }
        }).render('#paypal-button-container');

        paypalButtonsRendered = true;
    }
</script>

<!-- PayPal JS SDK Script -->
<script src="https://www.paypal.com/sdk/js?client-id=<%= paypalClientId %>&currency=USD"></script>
