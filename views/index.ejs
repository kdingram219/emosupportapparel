<!-- Homepage of Emotional Support Apparel by K&D -->

<!-- Hero Section -->
<section class="relative bg-[#F8F4EE] border-b border-charcoal/5 overflow-hidden py-16 lg:py-28">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        
        <!-- Left Content -->
        <div class="lg:col-span-6 space-y-8 animate-fade-in z-10">
            <div class="inline-flex items-center space-x-2 bg-gold/10 text-gold px-4 py-1.5 rounded-full text-xs font-semibold tracking-wider uppercase">
                <span>The Luxury of Being Seen</span>
            </div>
            
            <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-charcoal leading-[1.1]">
                Your <span class="italic text-gold underline decoration-1 underline-offset-8">Emotional Support</span> Hoodie Is Waiting.
            </h1>
            
            <p class="font-serif text-2xl text-charcoal/70 italic leading-relaxed">
                "Soft clothes. Hard life."
            </p>
            
            <p class="text-charcoal/60 text-base leading-relaxed max-w-lg">
                Premium, heavy-knit emotional-support gear featuring witty, relatable, internet-culture humor printed on luxury-quality fabrics. Not cheap merch — structured comfort with a personality that sells itself.
            </p>
            
            <!-- Dual-path CTAs -->
            <div class="flex flex-col sm:flex-row gap-4 pt-4">
                <a href="/collections/burnout" class="inline-flex items-center justify-center px-8 py-4 bg-charcoal hover:bg-charcoal/90 text-cream font-medium tracking-wide rounded-full shadow-lg hover:shadow-charcoal/20 hover:-translate-y-0.5 transition-all duration-300">
                    Shop Branded Collections
                </a>
                <a href="/design" class="inline-flex items-center justify-center px-8 py-4 border border-charcoal hover:border-gold hover:bg-gold/10 text-charcoal font-medium tracking-wide rounded-full hover:-translate-y-0.5 transition-all duration-300">
                    Design Your Own (Sublimation)
                </a>
            </div>
            
            <!-- Small Tagline -->
            <p class="text-xs text-charcoal/40 tracking-wider uppercase font-medium">
                ...because therapy is expensive
            </p>
        </div>
        
        <!-- Right Image/Graphic (Premium CSS/SVG Mockup) -->
        <div class="lg:col-span-6 flex justify-center z-10 relative">
            <div class="absolute -inset-4 bg-gradient-to-tr from-gold/10 to-dustyblue/15 rounded-3xl blur-2xl opacity-70 -z-10"></div>
            
            <!-- Luxury Hoodie Hero Showcase -->
            <div class="relative w-full max-w-md bg-cream/50 rounded-2xl p-8 border border-charcoal/5 shadow-2xl backdrop-blur-sm group hover:scale-[1.02] transition-all duration-500">
                <div class="absolute top-4 right-4 bg-gold text-charcoal text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full shadow-md">
                    Signature Luxury Piece
                </div>
                
                <!-- Hoodie outline SVG -->
                <svg class="w-full h-80 text-charcoal" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.5">
                    <!-- Sleeves -->
                    <path d="M40,90 C30,110 20,150 25,180 C27,190 35,190 40,180 L55,140" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M200,90 C210,110 220,150 215,180 C213,190 205,190 200,180 L185,140" stroke-linecap="round" stroke-linejoin="round"/>
                    <!-- Body core -->
                    <path d="M60,90 L60,195 C60,205 70,210 120,210 C170,210 180,205 180,195 L180,90 Z" fill="#2B2B2B" fill-opacity="0.05" stroke-linejoin="round"/>
                    <!-- Hem band -->
                    <path d="M60,195 C60,205 70,210 120,210 C170,210 180,205 180,195 C180,202 170,207 120,207 C70,207 60,202 60,195" fill="#2B2B2B" fill-opacity="0.1" stroke-linejoin="round"/>
                    <!-- Neck opening & Hood -->
                    <path d="M80,90 C80,60 100,35 120,35 C140,35 160,60 160,90 C160,70 145,55 120,55 C95,55 80,70 80,90" fill="#2B2B2B" fill-opacity="0.1" stroke-linecap="round" stroke-linejoin="round"/>
                    <!-- Pocket -->
                    <path d="M85,150 L155,150 L165,185 C165,190 160,195 155,195 L85,195 C80,195 75,190 75,185 Z" fill="#2B2B2B" fill-opacity="0.08" stroke-linejoin="round"/>
                    <path d="M85,150 L75,185 M155,150 L165,185" stroke-linecap="round"/>
                    <!-- Drawstrings -->
                    <path d="M110,92 L110,125 C110,128 107,130 105,130" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M130,92 L130,135 C130,138 133,140 135,140" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>

                <!-- Embroidered Branded Aesthetic overlay -->
                <div class="absolute inset-x-0 bottom-32 text-center select-none pointer-events-none px-12">
                    <span class="font-serif text-sm tracking-widest text-charcoal/80 uppercase font-bold block">
                        EMOTIONAL SUPPORT HOODIE
                    </span>
                    <span class="font-sans text-[10px] tracking-widest text-gold uppercase block mt-1">
                        ★ certified comfort piece ★
                    </span>
                </div>
                
                <!-- Card Detail -->
                <div class="border-t border-charcoal/10 mt-6 pt-4 flex justify-between items-center text-sm">
                    <div>
                        <p class="font-serif font-bold text-charcoal">Emotional Support Hoodie</p>
                        <p class="text-xs text-charcoal/50">Luxury French Terry · 450gsm</p>
                    </div>
                    <span class="text-gold font-bold">$78.00</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Predicted Best Sellers Section -->
<section class="py-24 bg-cream">
    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center space-y-4 mb-16">
            <p class="text-xs font-bold uppercase tracking-widest text-gold">Highly Predicted To Go Viral</p>
            <h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-charcoal">
                Branded Best Sellers
            </h2>
            <div class="w-16 h-0.5 bg-gold mx-auto"></div>
        </div>

        <!-- Product Cards Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            <% const featured = products.filter(p => p.collections.includes('best-sellers')).slice(0, 4); %>
            <% featured.forEach(product => { %>
                <div class="group bg-cream border border-charcoal/10 rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col h-full">
                    
                    <!-- Thumbnail with stylized CSS overlay -->
                    <div class="aspect-square bg-cream/40 border-b border-charcoal/5 relative flex items-center justify-center p-8 group-hover:bg-cream/20 transition-all duration-300">
                        <!-- Custom Product Outline SVG representation -->
                        <div class="w-full h-full flex items-center justify-center text-charcoal/60 group-hover:text-charcoal transition-colors duration-300">
                            <% if (product.category === 'hoodies') { %>
                                <svg class="w-40 h-40" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.2">
                                    <path d="M40,90 C30,110 20,150 25,180 C27,190 35,190 40,180 L55,140" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M200,90 C210,110 220,150 215,180 C213,190 205,190 200,180 L185,140" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M60,90 L60,195 C60,205 70,210 120,210 C170,210 180,205 180,195 L180,90 Z" fill="currentColor" fill-opacity="0.02" stroke-linejoin="round"/>
                                    <path d="M80,90 C80,60 100,35 120,35 C140,35 160,60 160,90 C160,70 145,55 120,55 C95,55 80,70 80,90" fill="currentColor" fill-opacity="0.05" stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M85,150 L155,150 L165,185 C165,190 160,195 155,195 L85,195 Z" fill="currentColor" fill-opacity="0.04"/>
                                </svg>
                            <% } else if (product.category === 'bags') { %>
                                <svg class="w-40 h-40" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.2">
                                    <!-- Tote bag body -->
                                    <path d="M50,80 L60,200 C60,205 65,210 70,210 L170,210 C175,210 180,205 190,200 L200,80 Z" fill="currentColor" fill-opacity="0.02" stroke-linejoin="round"/>
                                    <!-- Handles -->
                                    <path d="M90,80 L90,40 C90,35 100,30 120,30 C140,30 150,35 150,40 L150,80" stroke-linecap="round"/>
                                    <path d="M100,80 L100,45 C100,42 105,40 120,40 C135,40 140,42 140,45 L140,80" stroke-linecap="round" stroke-opacity="0.4"/>
                                </svg>
                            <% } else if (product.category === 'tees') { %>
                                <svg class="w-40 h-40" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.2">
                                    <!-- Tee outline -->
                                    <path d="M40,75 L75,55 L90,70 C100,60 110,58 120,58 C130,58 140,60 150,70 L165,55 L200,75 L185,110 L170,105 L170,200 C170,205 165,210 160,210 L80,210 C75,210 70,205 70,200 L70,105 L55,110 Z" fill="currentColor" fill-opacity="0.02" stroke-linejoin="round"/>
                                    <!-- Collar hem -->
                                    <path d="M90,70 C100,82 140,82 150,70" stroke-linecap="round"/>
                                </svg>
                            <% } else if (product.category === 'pillows') { %>
                                <svg class="w-40 h-40" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.2">
                                    <!-- Soft pillow square -->
                                    <path d="M45,45 C95,35 145,35 195,45 C205,95 205,145 195,195 C145,205 95,205 45,195 C35,145 35,95 45,45 Z" fill="currentColor" fill-opacity="0.02" stroke-linejoin="round"/>
                                    <!-- Pillow corner tuffs -->
                                    <path d="M45,45 L38,38 M195,45 L202,38 M195,195 L202,202 M45,195 L38,202" stroke-linecap="round"/>
                                </svg>
                            <% } else { %>
                                <svg class="w-40 h-40" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.2">
                                    <!-- General tumbler/mug shape -->
                                    <path d="M65,50 L175,50 L160,195 C160,202 155,205 145,205 L95,205 C85,205 80,202 80,195 Z" fill="currentColor" fill-opacity="0.02" stroke-linejoin="round"/>
                                    <path d="M60,50 L180,50" stroke-linecap="round"/>
                                    <path d="M65,70 L175,70" stroke-opacity="0.4"/>
                                </svg>
                            <% } %>
                        </div>
                        
                        <!-- Custom Badge overlay -->
                        <% if (product.badge) { %>
                            <span class="absolute top-3 left-3 bg-charcoal text-cream text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded">
                                <%= product.badge %>
                            </span>
                        <% } %>
                        
                        <!-- Witty Tag on Hover -->
                        <div class="absolute inset-0 bg-charcoal/95 opacity-0 group-hover:opacity-100 transition-opacity duration-300 p-6 flex flex-col justify-center items-center text-center">
                            <p class="text-gold font-serif italic text-base leading-relaxed mb-4">
                                "<%= product.wittyTag %>"
                            </p>
                            <span class="text-[10px] uppercase tracking-widest text-cream/60">Hover For Details</span>
                        </div>
                    </div>

                    <!-- Meta info -->
                    <div class="p-6 flex flex-col flex-grow justify-between bg-cream border-t border-charcoal/5">
                        <div class="space-y-2">
                            <span class="text-[10px] uppercase tracking-widest font-bold text-gold"><%= product.category %></span>
                            <h3 class="font-serif text-lg font-bold text-charcoal group-hover:text-gold transition-colors duration-200">
                                <a href="/products/<%= product.id %>"><%= product.name %></a>
                            </h3>
                            <p class="text-charcoal/50 text-xs line-clamp-2 leading-relaxed"><%= product.description %></p>
                        </div>
                        <div class="flex items-center justify-between pt-6 mt-auto border-t border-charcoal/5">
                            <span class="text-charcoal font-bold">$<%= product.price.toFixed(2) %></span>
                            <a href="/products/<%= product.id %>" class="text-xs tracking-wider uppercase font-semibold text-charcoal group-hover:text-gold flex items-center space-x-1 transition-all">
                                <span>Details</span>
                                <svg class="w-3 C-3 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path></svg>
                            </a>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
</section>

<!-- Social Proof / Sarcastic Rave Reviews -->
<section class="py-20 bg-charcoal text-cream relative overflow-hidden">
    <!-- Subtle architectural green blobs in background -->
    <div class="absolute top-0 right-0 w-80 h-80 bg-sage/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-dustyblue/10 rounded-full blur-3xl"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="text-center space-y-4 mb-16">
            <p class="text-xs font-bold uppercase tracking-widest text-gold">Don't Take Our Word For It</p>
            <h2 class="font-serif text-3xl sm:text-4xl font-bold tracking-tight text-cream">
                Sarcastic Rave Reviews
            </h2>
            <div class="w-16 h-0.5 bg-gold mx-auto"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            
            <!-- Review 1 -->
            <div class="bg-cream/5 border border-cream/10 p-8 rounded-2xl flex flex-col justify-between h-full space-y-6">
                <div class="space-y-4">
                    <div class="flex text-gold space-x-0.5">
                        <!-- 5 Star rating -->
                        <% for (let i = 0; i < 5; i++) { %>
                            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                        <% } %>
                    </div>
                    <p class="font-serif italic text-lg leading-relaxed text-cream/90">
                        "This hoodie understands me better than most people in my life. Extremely comfortable. Practically counts as therapy."
                    </p>
                </div>
                <div>
                    <p class="text-xs font-bold uppercase tracking-widest text-gold">Verified Buyer</p>
                    <p class="text-[10px] text-cream/40">Purchased: Emotional Support Hoodie</p>
                </div>
            </div>

            <!-- Review 2 -->
            <div class="bg-cream/5 border border-cream/10 p-8 rounded-2xl flex flex-col justify-between h-full space-y-6">
                <div class="space-y-4">
                    <div class="flex text-gold space-x-0.5">
                        <% for (let i = 0; i < 5; i++) { %>
                            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                        <% } %>
                    </div>
                    <p class="font-serif italic text-lg leading-relaxed text-cream/90">
                        "The Emotional Baggage Tote literally carries my problems, my keyboard, and my groceries. It's sturdier than my overall mental stability."
                    </p>
                </div>
                <div>
                    <p class="text-xs font-bold uppercase tracking-widest text-gold">Gen Z Survivor</p>
                    <p class="text-[10px] text-cream/40">Purchased: Emotional Baggage Tote</p>
                </div>
            </div>

            <!-- Review 3 -->
            <div class="bg-cream/5 border border-cream/10 p-8 rounded-2xl flex flex-col justify-between h-full space-y-6">
                <div class="space-y-4">
                    <div class="flex text-gold space-x-0.5">
                        <% for (let i = 0; i < 5; i++) { %>
                            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                        <% } %>
                    </div>
                    <p class="font-serif italic text-lg leading-relaxed text-cream/90">
                        "I wore the Currently Buffering hoodie to a family dinner. Nobody dared initiate conversation. Exceptional social boundaries. 10/10 highly effective."
                    </p>
                </div>
                <div>
                    <p class="text-xs font-bold uppercase tracking-widest text-gold">Overworked Millennial</p>
                    <p class="text-[10px] text-cream/40">Purchased: Currently Buffering Hoodie</p>
                </div>
            </div>

        </div>
    </div>
</section>

