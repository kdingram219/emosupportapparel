<!-- Homepage of Emotional Support Apparel by K&D — In-Your-Face Brand Vibe -->

<!-- Hero Section — HIT THEM IMMEDIATELY WITH THE BRAND -->
<section class="relative bg-charcoal text-cream overflow-hidden min-h-[90vh] flex items-center">
    <!-- Atmospheric gradients -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-gold/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-sage/10 rounded-full blur-3xl"></div>
    
    <div class="max-w-7xl mx-auto px-6 py-20 lg:py-32 relative z-10 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
            
            <!-- Left Content — Punchy, immediate attitude -->
            <div class="lg:col-span-6 space-y-8 animate-fade-in">
                <div class="inline-flex items-center space-x-2 bg-gold/15 text-gold px-4 py-1.5 rounded-full text-xs font-semibold tracking-wider uppercase">
                    <span>⚠️ Premium Emotional-Support Gear</span>
                </div>
                
                <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-cream leading-[1.05]">
                    ...because<br>
                    <span class="italic text-gold">therapy</span><br>
                    is expensive.
                </h1>
                
                <p class="font-sans text-lg sm:text-xl text-cream/70 max-w-lg leading-relaxed">
                    Luxury weight for your heavy thoughts. We can't fix your problems, but we can make sure you're the best-dressed person at your next spiral. 
                </p>
                
                <p class="text-gold font-serif italic text-base">
                    Soft clothes for a hard life. If you're going to be a mess, be an expensive mess.
                </p>
                
                <!-- Dual-path CTAs -->
                <div class="flex flex-col sm:flex-row gap-4 pt-4">
                    <a href="/collections/burnout" class="inline-flex items-center justify-center px-8 py-4 bg-gold hover:bg-gold/90 text-charcoal font-bold tracking-wide rounded-full shadow-lg hover:shadow-gold/20 hover:-translate-y-0.5 transition-all duration-300">
                        Shop Your Issues
                    </a>
                    <a href="/design" class="inline-flex items-center justify-center px-8 py-4 border border-cream/30 hover:border-gold hover:text-gold text-cream/90 font-medium tracking-wide rounded-full hover:-translate-y-0.5 transition-all duration-300">
                        Design Your Own
                    </a>
                </div>
            </div>
            
            <!-- Right — Bold Featured Product -->
            <div class="lg:col-span-6 flex justify-center">
                <% const heroProduct = products.find(p => p.id === 'emotional-support-hoodie'); %>
                <div class="relative w-full max-w-md group">
                    <div class="absolute -inset-4 bg-gradient-to-tr from-gold/20 to-dustyblue/20 rounded-3xl blur-2xl opacity-70 group-hover:opacity-100 transition-opacity duration-500"></div>
                    
                    <div class="relative bg-cream/5 border border-cream/10 rounded-2xl p-8 backdrop-blur-sm hover:border-gold/30 transition-all duration-500">
                        <div class="absolute -top-3 -right-3 bg-gold text-charcoal text-[10px] font-bold uppercase tracking-widest px-3 py-1.5 rounded-full shadow-lg animate-pulse-gold">
                            ★ Best Seller
                        </div>
                        
                        <!-- Design/Graphic at center — witty text as mock design -->
                        <div class="aspect-square flex items-center justify-center mb-4 relative">
                            <div class="w-full h-full flex flex-col items-center justify-center bg-charcoal/10 rounded-xl border border-cream/10 p-6">
                                <span class="font-serif text-lg tracking-widest text-gold uppercase font-bold text-center leading-relaxed">
                                    EMOTIONAL<br>SUPPORT<br>HOODIE
                                </span>
                                <div class="w-16 h-0.5 bg-gold/50 my-4"></div>
                                <span class="font-sans text-[10px] tracking-widest text-cream/50 uppercase text-center">
                                    ★ certified comfort piece ★
                                </span>
                            </div>
                        </div>
                        
                        <div class="border-t border-cream/10 pt-4 flex justify-between items-center">
                            <div>
                                <p class="font-serif font-bold text-cream text-lg"><%= heroProduct.name %></p>
                                <p class="text-xs text-cream/50"><%= heroProduct.wittyTag.substring(0, 50) %>...</p>
                            </div>
                            <span class="text-gold font-bold text-xl">$<%= heroProduct.price.toFixed(2) %></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Predicted Best Sellers — WITTY TAGLINES VISIBLE RIGHT AWAY, NO HOVER NEEDED -->
<section class="py-24 bg-cream">
    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center space-y-4 mb-16">
            <p class="text-xs font-bold uppercase tracking-widest text-gold">⚡ Viral Potential Detected</p>
            <h2 class="font-serif text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-charcoal">
                Branded Best Sellers
            </h2>
            <p class="text-charcoal/50 text-sm max-w-lg mx-auto">The ones that sell themselves. <span class="italic">(No really, we just stock them.)</span></p>
            <div class="w-16 h-0.5 bg-gold mx-auto"></div>
        </div>

        <!-- Product Cards Grid — witty tags visible IMMEDIATELY, not on hover -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 stagger-children">
            <% const featured = products.filter(p => p.collections.includes('best-sellers')).slice(0, 8); %>
            <% featured.forEach(product => { %>
                <div class="group bg-cream border border-charcoal/10 rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col h-full">
                    
                    <!-- Design/Graphic area — text design as the product graphic -->
                    <div class="aspect-square bg-charcoal/5 relative flex items-center justify-center p-6 group-hover:bg-charcoal/10 transition-all duration-300 border-b border-charcoal/5">
                        <div class="w-full h-full flex flex-col items-center justify-center text-center p-4">
                            <!-- Display the witty design text as the product graphic -->
                            <% if (product.designText) { %>
                                <span class="font-serif text-sm font-bold text-charcoal tracking-tight leading-tight uppercase whitespace-pre-line">
                                    <%= product.designText %>
                                </span>
                            <% } else { %>
                                <span class="font-serif text-sm text-charcoal/50 italic"><%= product.name %></span>
                            <% } %>
                        </div>
                        
                        <!-- Badge overlay -->
                        <% if (product.badge) { %>
                            <span class="absolute top-3 left-3 bg-charcoal text-cream text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded">
                                <%= product.badge %>
                            </span>
                        <% } %>
                    </div>

                    <!-- Card Meta — wittyTag RIGHT HERE, always visible -->
                    <div class="p-5 flex flex-col flex-grow justify-between bg-cream">
                        <div class="space-y-2">
                            <span class="text-[10px] uppercase tracking-widest font-bold text-gold"><%= product.category %></span>
                            <h3 class="font-serif text-base font-bold text-charcoal group-hover:text-gold transition-colors duration-200">
                                <a href="/products/<%= product.id %>"><%= product.name %></a>
                            </h3>
                            <!-- WITTY TAG — always visible, bold, italic, in gold -->
                            <p class="font-serif italic text-xs text-gold/80 leading-relaxed">
                                "<%= product.wittyTag %>"
                            </p>
                        </div>
                        <div class="flex items-center justify-between pt-4 mt-auto border-t border-charcoal/5">
                            <span class="text-charcoal font-bold">$<%= product.price.toFixed(2) %></span>
                            <a href="/products/<%= product.id %>" class="text-xs tracking-wider uppercase font-semibold text-charcoal group-hover:text-gold flex items-center space-x-1 transition-all">
                                <span>Details</span>
                                <svg class="w-3 h-3 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path></svg>
                            </a>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
        
        <div class="text-center mt-12">
            <a href="/collections/burnout" class="inline-flex items-center justify-center px-8 py-3 border border-charcoal hover:bg-charcoal hover:text-cream text-charcoal font-medium tracking-wide rounded-full transition-all duration-300 text-sm">
                View All Collections
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
        </div>
    </div>
</section>

