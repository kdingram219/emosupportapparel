<!-- Collection Page of Emotional Support Apparel by K&D -->

<!-- Header Section with Collection Identity -->
<section class="bg-cream border-b border-charcoal/5 py-12 sm:py-20 animate-fade-in">
    <div class="max-w-7xl mx-auto px-6 text-center space-y-6">
        
        <!-- Breadcrumb -->
        <div class="flex items-center justify-center space-x-2 text-xs uppercase tracking-widest text-charcoal/40">
            <a href="/" class="hover:text-gold transition-colors">Home</a>
            <span>/</span>
            <span class="text-charcoal/80">Collections</span>
            <span>/</span>
            <span class="text-charcoal"><%= collectionName %></span>
        </div>
        
        <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-charcoal">
            <%= collectionName %>
        </h1>
        
        <!-- Sarcastic/Witty tagline for the collection -->
        <% if (typeof collectionTagline !== 'undefined' && collectionTagline) { %>
            <p class="font-serif text-xl sm:text-2xl text-gold italic max-w-2xl mx-auto leading-relaxed">
                "<%= collectionTagline %>"
            </p>
            <p class="text-charcoal/60 text-sm max-w-xl mx-auto leading-relaxed">
                <%= collectionDescription %>
            </p>
        <% } else { %>
            <p class="font-serif text-xl sm:text-2xl text-gold italic max-w-2xl mx-auto leading-relaxed">
                "<%= collectionDescription %>"
            </p>
        <% } %>

        <!-- Category Filters -->
        <div class="flex flex-wrap justify-center gap-3 pt-6">
            <a href="/collections/<%= collectionId %>" class="px-5 py-2 rounded-full text-xs font-semibold tracking-wider uppercase border transition-all duration-300 <%= !activeCategory ? 'bg-charcoal text-cream border-charcoal' : 'bg-cream text-charcoal/70 border-charcoal/10 hover:border-charcoal hover:text-charcoal' %>">
                All Items
            </a>
            <% const categories = ["hoodies", "tees", "hats", "mugs", "tumblers", "bags", "pillows", "pens", "signs"]; %>
            <% categories.forEach(cat => { %>
                <a href="/collections/<%= collectionId %>?category=<%= cat %>" class="px-5 py-2 rounded-full text-xs font-semibold tracking-wider uppercase border transition-all duration-300 <%= activeCategory === cat ? 'bg-charcoal text-cream border-charcoal' : 'bg-cream text-charcoal/70 border-charcoal/10 hover:border-charcoal hover:text-charcoal' %>">
                    <%= cat %>
                </a>
            <% }); %>
        </div>

    </div>
</section>

<!-- Product List Grid -->
<section class="py-16 sm:py-24 bg-[#F8F4EE]">
    <div class="max-w-7xl mx-auto px-6">
        
        <% if (filteredProducts.length === 0) { %>
            <div class="text-center py-16 space-y-4">
                <span class="text-4xl block">🔍</span>
                <p class="font-serif text-xl text-charcoal/60">We don't have this item type in this collection yet.</p>
                <p class="text-sm text-charcoal/40">But you can design your own instantly!</p>
                <div class="pt-4">
                    <a href="/design" class="inline-flex items-center justify-center px-6 py-3 bg-gold hover:bg-gold/95 text-charcoal font-bold text-xs tracking-wider uppercase rounded-full transition-all">
                        Design a Custom <%= activeCategory || 'Product' %>
                    </a>
                </div>
            </div>
        <% } else { %>
            <!-- Grid list -->
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
                <% filteredProducts.forEach(product => { %>
                    <div class="group bg-cream border border-charcoal/10 rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col h-full">
                        
                        <!-- Product representation -->
                        <div class="aspect-square bg-cream/40 border-b border-charcoal/5 relative flex items-center justify-center p-8 group-hover:bg-cream/20 transition-all duration-300">
                            <div class="w-full h-full flex items-center justify-center text-charcoal/60 group-hover:text-charcoal transition-colors duration-300">
                                <% if (product.category === 'hoodies') { %>
                                    <svg class="w-44 h-44" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.2">
                                        <path d="M40,90 C30,110 20,150 25,180 C27,190 35,190 40,180 L55,140" stroke-linecap="round" stroke-linejoin="round"/>
                                        <path d="M200,90 C210,110 220,150 215,180 C213,190 205,190 200,180 L185,140" stroke-linecap="round" stroke-linejoin="round"/>
                                        <path d="M60,90 L60,195 C60,205 70,210 120,210 C170,210 180,205 180,195 L180,90 Z" fill="currentColor" fill-opacity="0.02" stroke-linejoin="round"/>
                                        <path d="M80,90 C80,60 100,35 120,35 C140,35 160,60 160,90 C160,70 145,55 120,55 C95,55 80,70 80,90" fill="currentColor" fill-opacity="0.05" stroke-linecap="round" stroke-linejoin="round"/>
                                        <path d="M85,150 L155,150 L165,185 C165,190 160,195 155,195 L85,195 Z" fill="currentColor" fill-opacity="0.04"/>
                                    </svg>
                                <% } else if (product.category === 'bags') { %>
                                    <svg class="w-44 h-44" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.2">
                                        <path d="M50,80 L60,200 C60,205 65,210 70,210 L170,210 C175,210 180,205 190,200 L200,80 Z" fill="currentColor" fill-opacity="0.02" stroke-linejoin="round"/>
                                        <path d="M90,80 L90,40 C90,35 100,30 120,30 C140,30 150,35 150,40 L150,80" stroke-linecap="round"/>
                                        <path d="M100,80 L100,45 C100,42 105,40 120,40 C135,40 140,42 140,45 L140,80" stroke-linecap="round" stroke-opacity="0.4"/>
                                    </svg>
                                <% } else if (product.category === 'tees') { %>
                                    <svg class="w-44 h-44" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.2">
                                        <path d="M40,75 L75,55 L90,70 C100,60 110,58 120,58 C130,58 140,60 150,70 L165,55 L200,75 L185,110 L170,105 L170,200 C170,205 165,210 160,210 L80,210 C75,210 70,205 70,200 L70,105 L55,110 Z" fill="currentColor" fill-opacity="0.02" stroke-linejoin="round"/>
                                        <path d="M90,70 C100,82 140,82 150,70" stroke-linecap="round"/>
                                    </svg>
                                <% } else if (product.category === 'pillows') { %>
                                    <svg class="w-44 h-44" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.2">
                                        <path d="M45,45 C95,35 145,35 195,45 C205,95 205,145 195,195 C145,205 95,205 45,195 C35,145 35,95 45,45 Z" fill="currentColor" fill-opacity="0.02" stroke-linejoin="round"/>
                                        <path d="M45,45 L38,38 M195,45 L202,38 M195,195 L202,202 M45,195 L38,202" stroke-linecap="round"/>
                                    </svg>
                                <% } else if (product.category === 'hats') { %>
                                    <svg class="w-44 h-44" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.2">
                                        <!-- Baseball cap cap dome -->
                                        <path d="M50,150 C50,70 190,70 190,150 Z" fill="currentColor" fill-opacity="0.02"/>
                                        <!-- Brim -->
                                        <path d="M30,150 C50,140 190,140 210,150 C220,155 200,165 120,165 C40,165 20,155 30,150 Z" fill="currentColor" fill-opacity="0.05"/>
                                        <path d="M120,150 L120,85 M85,145 C85,110 110,95 120,95" stroke-dasharray="2,2"/>
                                    </svg>
                                <% } else if (product.category === 'mugs') { %>
                                    <svg class="w-44 h-44" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.2">
                                        <!-- Mug cylinder -->
                                        <path d="M70,70 L170,70 L170,180 C170,195 160,200 150,200 L90,200 C80,200 70,195 70,180 Z" fill="currentColor" fill-opacity="0.02" stroke-linejoin="round"/>
                                        <!-- Handle -->
                                        <path d="M70,90 C45,90 45,160 70,160" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                <% } else if (product.category === 'pens') { %>
                                    <svg class="w-44 h-44" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.2">
                                        <!-- Sleek pen -->
                                        <path d="M40,200 L50,190 L180,60 L170,50 L40,180 Z" fill="currentColor" fill-opacity="0.05" stroke-linejoin="round"/>
                                        <path d="M40,200 L35,205 L40,180" stroke-linejoin="round"/>
                                        <path d="M160,80 L150,70" stroke-width="2"/>
                                    </svg>
                                <% } else { %>
                                    <svg class="w-44 h-44" viewBox="0 0 240 240" fill="none" stroke="currentColor" stroke-width="1.2">
                                        <path d="M65,50 L175,50 L160,195 C160,202 155,205 145,205 L95,205 C85,205 80,202 80,195 Z" fill="currentColor" fill-opacity="0.02" stroke-linejoin="round"/>
                                        <path d="M60,50 L180,50" stroke-linecap="round"/>
                                    </svg>
                                <% } %>
                            </div>

                            <% if (product.badge) { %>
                                <span class="absolute top-3 left-3 bg-charcoal text-cream text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded">
                                    <%= product.badge %>
                                </span>
                            <% } %>
                            
                            <!-- Custom Witty Tag Overlay on Hover -->
                            <div class="absolute inset-0 bg-charcoal/95 opacity-0 group-hover:opacity-100 transition-opacity duration-300 p-6 flex flex-col justify-center items-center text-center">
                                <p class="text-gold font-serif italic text-base leading-relaxed mb-4">
                                    "<%= product.wittyTag %>"
                                </p>
                                <span class="text-[10px] uppercase tracking-widest text-cream/50">Read Witty Tag</span>
                            </div>
                        </div>

                        <!-- Card Meta -->
                        <div class="p-6 flex flex-col flex-grow justify-between bg-cream border-t border-charcoal/5">
                            <div class="space-y-2">
                                <span class="text-[10px] uppercase tracking-widest font-bold text-gold"><%= product.category %></span>
                                <h3 class="font-serif text-xl font-bold text-charcoal group-hover:text-gold transition-colors duration-200">
                                    <a href="/products/<%= product.id %>"><%= product.name %></a>
                                </h3>
                                <p class="text-charcoal/50 text-xs line-clamp-2 leading-relaxed"><%= product.description %></p>
                            </div>
                            <div class="flex items-center justify-between pt-6 mt-auto border-t border-charcoal/5">
                                <span class="text-charcoal font-bold text-lg">$<%= product.price.toFixed(2) %></span>
                                <a href="/products/<%= product.id %>" class="text-xs tracking-wider uppercase font-semibold text-charcoal group-hover:text-gold flex items-center space-x-1 transition-all">
                                    <span>Examine</span>
                                    <svg class="w-3 h-3 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path></svg>
                                </a>
                            </div>
                        </div>

                    </div>
                <% }); %>
            </div>
        <% } %>

    </div>
</section>
